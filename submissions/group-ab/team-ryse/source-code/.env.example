# Google Generative AI API URL
# The base URL for the Google Generative AI API endpoint
# Use default URL for official Google Generative AI API
# Can be customized for regional endpoints or alternative endpoints
AI_GOOGLE_GENAI_API_URL=https://generativelanguage.googleapis.com/v1beta

# Google Generative AI API Key
# The API key for authenticating with Google's Generative AI models (Gemini)
# Get your API key from https://aistudio.google.com/app/apikey
AI_GOOGLE_GENAI_API_KEY=

# Agora Application ID (public, exposed to client-side)
# Get your App ID from https://console.agora.io/
NEXT_PUBLIC_AGORA_APP_ID=

# Agora Application ID (server-side)
AGORA_APP_ID=

# Agora Application Secret
# Used for server-side token generation and API authentication
AGORA_APP_SECRET=

# Agora Customer Key
# Used for Agora REST API access (e.g., channel management, recording)
AGORA_CUSTOMER_KEY=

# Agora Customer Secret
# Paired with the Customer Key for Agora REST API authentication
AGORA_CUSTOMER_SECRET=

# Agora Channel Name
# The real-time communication channel where agent, judge, and counsel interact
AGORA_CHANNEL=

# Agora Channel Temporary Token
# Short-lived token for authenticating into the Agora channel
AGORA_CHANNEL_TEMP_TOKEN=

# User ID for the AI Agent in the Agora channel
NEXT_PUBLIC_AGENT_UID=12345

# User ID for the Judge role in the Agora channel
NEXT_PUBLIC_JUDGE_UID=1001

# User ID for the Counsel role in the Agora channel
NEXT_PUBLIC_COUNSEL_UID=2001

# Custom LLM API endpoint for the Agent
# OpenAI-compatible chat completions endpoint
CUSTOM_LLM_URL=https://aiss-macbook-pro.ladon-matrix.ts.net/api/chat/completions

# Custom LLM API endpoint for the Judge role
# Separate endpoint to isolate judge-specific prompts and behavior
CUSTOM_LLM_URL_JUDGE=https://aiss-macbook-pro.ladon-matrix.ts.net/api/chat/completions/judge

# Custom LLM API endpoint for the Counsel role
# Separate endpoint to isolate counsel-specific prompts and behavior
CUSTOM_LLM_URL_COUNSEL=https://aiss-macbook-pro.ladon-matrix.ts.net/api/chat/completions/counsel
