# Agora Voice AI Hackathon - local backend configuration
# Copy this file to .env and fill in the three Agora values before demo testing.
# Keep .env local. Do not commit real credentials.

# Required for Agora RTC token generation and Conversational AI Engine agent startup.
VOICE_APP_ID=your_agora_app_id
VOICE_APP_CERTIFICATE=your_agora_app_certificate
VOICE_PIPELINE_ID=your_32_character_agent_builder_pipeline_id

# Agora Conversational AI REST endpoint used by the sample backend.
VOICE_AGENT_ENDPOINT=https://api.agora.io/api/conversational-ai-agent/v2/projects

# Agent behavior. Keep responses short for a live hackathon demo.
VOICE_DEFAULT_GREETING=Hi Grandpa, I'm CareKaki. I'm here whenever you want to talk.
VOICE_DEFAULT_PROMPT=You are CareKaki, a warm voice companion for an elderly person in Singapore. Speak simply and gently. Your job is companionship, food check-ins, medication check-ins, mood check-ins, and family escalation. Do not diagnose, prescribe, or give medical instructions beyond safe general advice. If the user mentions dizziness, falling, chest tightness, breathing trouble, or possible double medication, calmly ask them to sit down, avoid taking extra medicine, keep the phone nearby, and say you will alert family. Ask one question at a time. Keep responses under 25 words.
VOICE_DEFAULT_FAILURE_MESSAGE=Sorry, I had trouble responding. Please say that again slowly.

# Voice and turn-taking defaults.
VOICE_ASR_VENDOR=ares
VOICE_ASR_LANGUAGE=en-US
VOICE_VAD_SILENCE_DURATION_MS=300
VOICE_ENABLE_AIVAD=true
VOICE_IDLE_TIMEOUT=120
VOICE_MAX_HISTORY=32

# Local debugging only. The generated curl dumps stay in /tmp and must not be committed.
VOICE_ENABLE_CURL_DUMP=true
